{
  "info": {
    "name": "PhoneStore API",
    "_postman_id": "phonestore-collection",
    "description": "API collection cho dự án Phone Store",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "otpCode", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "productSlug", "value": "iphone-15-pro-max" },
    { "key": "variantId", "value": "" }
  ],
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.otp) {",
                  "  pm.collectionVariables.set('otpCode', res.otp);",
                  "  console.log('✅ OTP saved:', res.otp);",
                  "  pm.test('OTP nhận được: ' + res.otp, () => pm.expect(res.otp).to.have.lengthOf(6));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nguyễn Văn A\",\n  \"email\": \"test@gmail.com\",\n  \"password\": \"123456\",\n  \"phone\": \"0912345678\"\n}"
            }
          }
        },
        {
          "name": "Verify OTP ⭐",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "  console.log('✅ Verified! Token saved.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/verify-otp",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@gmail.com\",\n  \"code\": \"{{otpCode}}\",\n  \"type\": \"verify_email\"\n}"
            }
          }
        },
        {
          "name": "Login ⭐",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "  console.log('✅ Token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "  console.log('✅ Admin token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Get Me (Profile)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) pm.collectionVariables.set('accessToken', res.data.accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh-token",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/reset-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\",\n  \"code\": \"123456\",\n  \"newPassword\": \"newpass123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "📱 Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?page=1&limit=10&sort=newest",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "sort", "value": "newest", "description": "newest | price_asc | price_desc | popular | rating" }
              ]
            }
          }
        },
        {
          "name": "Get Products - Filter by Brand",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?brand=apple&sort=popular",
              "query": [
                { "key": "brand", "value": "apple" },
                { "key": "sort", "value": "popular" }
              ]
            }
          }
        },
        {
          "name": "Get Products - Filter by Price",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?minPrice=5000000&maxPrice=20000000",
              "query": [
                { "key": "minPrice", "value": "5000000" },
                { "key": "maxPrice", "value": "20000000" }
              ]
            }
          }
        },
        {
          "name": "Get Featured Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/featured"
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/search?q=iphone",
              "query": [{ "key": "q", "value": "iphone" }]
            }
          }
        },
        {
          "name": "Get Product by Slug",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.variants?.[0]) {",
                  "  pm.collectionVariables.set('variantId', res.data.variants[0]._id);",
                  "  console.log('✅ variantId saved:', res.data.variants[0]._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/{{productSlug}}"
          }
        },
        {
          "name": "Compare Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/compare?ids=ID1,ID2",
              "query": [{ "key": "ids", "value": "ID1,ID2", "description": "Thay bằng _id thực từ response" }]
            }
          }
        }
      ]
    },
    {
      "name": "🏷️ Brands & Categories",
      "item": [
        {
          "name": "Get All Brands",
          "request": { "method": "GET", "url": "{{baseUrl}}/brands" }
        },
        {
          "name": "Get Brand by Slug",
          "request": { "method": "GET", "url": "{{baseUrl}}/brands/apple" }
        },
        {
          "name": "Get All Categories",
          "request": { "method": "GET", "url": "{{baseUrl}}/categories" }
        },
        {
          "name": "Get Category by Slug",
          "request": { "method": "GET", "url": "{{baseUrl}}/categories/iphone" }
        }
      ]
    },
    {
      "name": "🛒 Cart (cần login)",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/cart",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Add Item to Cart ⭐",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/cart/items",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"variantId\": \"{{variantId}}\",\n  \"quantity\": 1\n}"
            }
          }
        },
        {
          "name": "Update Cart Item",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/cart/items/{{variantId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 2\n}"
            }
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/cart/items/{{variantId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Hold Stock (bắt đầu checkout)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/cart/hold",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Release Hold (hủy checkout)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/cart/release",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Clear Cart",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/cart",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        }
      ]
    },
    {
      "name": "📦 Orders (cần login)",
      "item": [
        {
          "name": "Create Order ⭐",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?._id) {",
                  "  pm.collectionVariables.set('orderId', res.data._id);",
                  "  console.log('✅ orderId saved:', res.data._id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/orders",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": {\n    \"fullName\": \"Nguyễn Văn A\",\n    \"phone\": \"0912345678\",\n    \"address\": \"123 Nguyễn Huệ\",\n    \"city\": \"TP. Hồ Chí Minh\",\n    \"district\": \"Quận 1\"\n  },\n  \"paymentMethod\": \"cod\",\n  \"note\": \"Giao giờ hành chính\"\n}"
            }
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/orders?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "", "disabled": true, "description": "pending|confirmed|shipping|delivered|cancelled" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/{{orderId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/orders/{{orderId}}/cancel",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Tôi muốn thay đổi địa chỉ giao hàng\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "🏥 Health Check",
      "item": [
        {
          "name": "Server Health",
          "request": { "method": "GET", "url": "{{baseUrl}}/health" }
        }
      ]
    }
  ]
}
